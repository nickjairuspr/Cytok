{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/chat",    "destination": "/api/chat" },
    { "source": "/api/models",  "destination": "/api/models" },
    { "source": "/api/healthz", "destination": "/api/healthz" },
    { "source": "/(.*)",        "destination": "/index.html" }
  ]
}
